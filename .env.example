# --- Repo + Git identity ---
TARGET_REPO_URL=git@github.com:YOUR_USERNAME/YOUR_REPO.git
TARGET_REPO_DIR=./target-repo
GIT_USER_NAME=Your Name
GIT_USER_EMAIL=you@example.com

# --- Commit behavior ---
MIN_COMMITS=1
MAX_COMMITS=5
HEARTBEAT_FILE=.auto-commit-heartbeat
COMMIT_MESSAGE_PREFIX=chore: daily activity

# If running from GitHub Actions to push into a private repo, set TARGET_REPO_URL
# in GitHub Secrets with a tokenized https URL, for example:
# https://x-access-token:YOUR_PAT@github.com/YOUR_USERNAME/YOUR_REPO.git
